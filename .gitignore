# Generated by Cargo
# will have compiled files and executables
debug/
target/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/
.DS_STORE

# Security vulnerability audit reports (CONFIDENTIAL - do not commit)
docs/security/VULNERABILITY_AUDIT_*.mdservices/web-ui/dist/
services/web-ui/node_modules/

# Kubeconfig files (contain cluster-admin credentials - do not commit)
*.kubeconfig
kubeconfig

# Cluster admin credentials - never commit
ostrich.kubeconfig
*.kubeconfig

# Cluster-specific test deploy (dev creds, node pinning)
deploy/cluster/

# Stray curl cookie jars from local verification (never commit; may hold session tokens)
/cj*.txt
/*.cookies
