# OstrichPKI Environment Configuration Template
#
# COMPLIANCE MAPPING:
# - NIST 800-53: CM-6 (Configuration Settings)
# - NIST 800-53: SC-28 (Protection of Information at Rest)
#
# Copy this file to .env and configure for your environment.
# NEVER commit .env files containing secrets to version control.

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_USER=ostrich
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD
POSTGRES_DB=ostrich_pki

# =============================================================================
# Logging Configuration
# =============================================================================
# Log level: trace, debug, info, warn, error
RUST_LOG=info
# Use JSON format for structured logging in production
LOG_JSON=true

# =============================================================================
# CA Service Configuration
# =============================================================================
# CA certificate and key files (PEM format)
# Required for full CA functionality
CA_CERT_FILE=/app/certs/ca.pem
CA_KEY_FILE=/app/certs/ca-key.pem

# =============================================================================
# ACME Service Configuration
# =============================================================================
# External base URL for ACME directory (used for URLs in responses)
ACME_BASE_URL=https://acme.example.com

# =============================================================================
# EST Service Configuration
# =============================================================================
# TLS configuration for EST (requires mTLS per RFC 7030)
EST_TLS_CERT_FILE=/app/certs/est-service.pem
EST_TLS_KEY_FILE=/app/certs/est-service-key.pem
EST_TLS_CA_CERT_FILE=/app/certs/root-ca.pem

# =============================================================================
# OCSP Service Configuration
# =============================================================================
# OCSP signing certificate and key
OCSP_SIGNING_CERT=/app/certs/ocsp-signer.pem
OCSP_SIGNING_KEY=/app/certs/ocsp-signer-key.pem

# =============================================================================
# HSM Configuration (optional)
# =============================================================================
# PKCS#11 library path for HSM integration
# HSM_PKCS11_LIBRARY=/usr/lib/softhsm/libsofthsm2.so
# HSM_SLOT=0
# HSM_PIN=CHANGE_ME_HSM_PIN
