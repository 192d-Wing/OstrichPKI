# notify-service variable file (git-controlled).
#
# Edit these and re-apply (`kubectl apply -k deploy/kubernetes/notify/`) to
# reconfigure the SMTP relay and scheduler. kustomize folds this into a hashed
# ConfigMap and the scheduler/sender Deployments read it via envFrom, so a change
# here triggers a rollout automatically.
#
# NOTE: secrets do NOT belong here. The DB connection string is in
# `notify-db-secret`; SMTP credentials (if your relay needs auth) go in a
# `notify-smtp-secret` referenced from notify-deployments.yaml.

# --- Queue ---
NATS_URL=nats://nats:4222

# --- Scheduler ---
NOTIFY_TICK_SECONDS=300

# --- SMTP relay (sender) ---
SMTP_HOST=smtp.oopl.dev.mil
SMTP_PORT=587
SMTP_FROM=pki-notify@oopl.dev.mil
# Force implicit TLS (SMTPS) from connection start. true is typically port 465;
# false connects in plaintext to a trusted internal relay.
SMTP_TLS=false
