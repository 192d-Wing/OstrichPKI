{
  "$schema": "./schema/est-server.schema.json",

  "bindAddress": "0.0.0.0:8443",

  "databaseUrl": "postgresql://ostrich@db.example.com:5432/ostrich?sslmode=require",

  "caGrpcUrl": "https://ostrich-ca:50051",
  "caGrpcClientCert": "/etc/ostrich/est/ca-client.crt",
  "caGrpcClientKey": "/etc/ostrich/est/ca-client.key",
  "caGrpcCaCert": "/etc/ostrich/est/ca-server-ca.crt",
  "caInsecure": false,

  "enrollProfile": "tls_client",
  "enrollIdentityPolicy": "username",

  "tlsCert": "/etc/ostrich/est/server.crt",
  "tlsKey": "/etc/ostrich/est/server.key",
  "tlsCaCert": "/etc/ostrich/est/client-ca.crt",

  "allowBasicAuth": false,
  "allowBearerAuth": false,

  "caBackends": [
    {
      "name": "ec",
      "grpcUrl": "https://ostrich-ca-ec:50051",
      "clientCert": "/etc/ostrich/est/ca-client.crt",
      "clientKey": "/etc/ostrich/est/ca-client.key",
      "caCert": "/etc/ostrich/est/ca-server-ca.crt",
      "caCertificateId": "00000000-0000-0000-0000-0000000000ec"
    },
    {
      "name": "rsa",
      "grpcUrl": "https://ostrich-ca-rsa:50051",
      "clientCert": "/etc/ostrich/est/ca-client.crt",
      "clientKey": "/etc/ostrich/est/ca-client.key",
      "caCert": "/etc/ostrich/est/ca-server-ca.crt",
      "caCertificateId": "00000000-0000-0000-0000-00000000a5a0"
    }
  ],
  "labelRouting": {
    "algoBackends": { "P384": "ec", "2048": "rsa" },
    "defaultBackend": "ec"
  },

  "logLevel": "info",
  "logJson": true
}
